# Telegram Bot Configuration
BOT_TOKEN=123456:ABC-DEF
WEBHOOK_SECRET=replace-with-a-long-random-string

# Deployment Configuration
PUBLIC_URL=https://your-vercel-app.vercel.app

# Supabase Configuration
SUPABASE_URL=https://abc.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role-key

# Prisma / Supabase only
# Direct connection (migrations/introspection)
DIRECT_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require

# Optional pooled runtime (pgBouncer) for app runtime
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@<POOLER_HOST>:6543/postgres?pgbouncer=true&sslmode=require

# AI / Processing
# Required for the Reels understanding pipeline
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

# Instagram resolution (optional; improves success rate)
# Set a logged-in cookie value and install Playwright to resolve media reliably
# IG_SESSION_ID=your_instagram_sessionid_cookie
# IG_USER_AGENT=Your UA string (optional)

# Facebook OAuth (optional)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
# Must point to this backend service callback route
FACEBOOK_REDIRECT_URI=https://your-backend-domain.com/auth/facebook/callback
FACEBOOK_LOGIN_SCOPES=pages_show_list,pages_read_engagement,pages_manage_metadata,instagram_manage_messages
FACEBOOK_GRAPH_API_VERSION=v24.0
# Comma-separated list of trusted frontend callback pages
FACEBOOK_ALLOWED_RETURN_URLS=https://your-frontend-domain.com/auth/facebook/connect,http://localhost:3000/auth/facebook/connect
